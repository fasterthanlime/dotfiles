{
  "agent_servers": {
    "claude": {
      "default_config_options": {
        "mode": "bypassPermissions",
      },
    },
    "codex": {
      "favorite_config_option_values": {
        "mode": ["full-access"],
      },
    },
  },
  "use_system_path_prompts": true,
  "use_system_prompts": false,
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_profile": "write",
    "show_turn_stats": true,
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "theme": {
    "dark": "Melange Dark",
    "light": "Melange Light",
  },
  "terminal": {
    "font_family": "Maple Mono NF",
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Maple Mono",
  "vim_mode": true,
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
          "workspace": true,
        },
      },
    },
  },
}
